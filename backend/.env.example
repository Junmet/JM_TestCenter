# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=jmtestcenter
MYSQL_PASSWORD=jmtestcenter_password
MYSQL_DB=jmtestcenter

# JWT (access token)
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_ACCESS_EXPIRE_MINUTES=15

# Refresh token
REFRESH_TOKEN_EXPIRE_DAYS=30

# JWT settings
JWT_ALG=HS256
JWT_ISSUER=jmtestcenter

# Seed dev admin user
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin12345

# UI 自动化 Midscene：是否在子进程启用「额外 networkidle 等待」（默认 false，SPA 易卡）
# MIDSCENE_SETTLE_NETWORK_IDLE=true

# UI 自动化：单次 Node 任务最长秒数（默认 3600）。长时间 running 可改小以更快失败，如 900
# MIDSCENE_RUN_TIMEOUT_SECONDS=900

# Midscene 运行器目录（默认 backend/midscene-runner，一般无需修改）
# MIDSCENE_RUNNER_DIR=E:/path/to/backend/midscene-runner

# 纯 Playwright 运行器目录（默认 backend/playwright-runner，一般无需修改）
# PLAYWRIGHT_RUNNER_DIR=E:/path/to/backend/playwright-runner
