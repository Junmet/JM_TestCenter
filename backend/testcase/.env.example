DEEPSEEK_API_KEY=your_key_here
# 可选。DeepSeek OpenAI 兼容接口 base url（不要以 /v1 结尾也可，脚本会兼容）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选。常见：deepseek-chat / deepseek-reasoner（以你账号开通为准）
DEEPSEEK_MODEL=deepseek-chat
# 可选。请求超时秒数、单次回复最大 token 数
# DEEPSEEK_TIMEOUT=120
# DEEPSEEK_MAX_TOKENS=16384

# 可选：输出默认语言（zh/en）
APP_LANGUAGE=zh
